# Database - SQLite file path (relative to prisma/ directory)
DATABASE_URL="file:./dev.db"

# URL where the service is accessible
EXTERNAL_SERVICE_URL="http://localhost:3000"

# Workspace directory (absolute path or relative to project root)
WORKSPACE_DIR=./my_workspaces

# JWT Secret - generate a secure random string for production
JWT_SECRET=your-secret-key

# Server Configuration
HOST=0.0.0.0
PORT=3000

# Opencode Server Configuration
OPENCODE_PORT=4096
OPENCODE_MODEL=anthropic/claude-sonnet-4-5-20250929
