generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model users {
  id                         String                          @id @default(uuid())
  email                      String                          @unique
  name                       String
  role                       String // "User" or "Engineer"
  created_at                 BigInt
  password_hash              String
  must_change_password       Boolean                         @default(false)
  reset_token                String?
  reset_token_expires_at     BigInt?
  workflowRuns               workflow_runs[]
  chatSessions               chat_sessions[]
  resourcePermissionUsers    resource_permission_users[]
  createdResourceMetadata    resource_metadata[]             @relation("ResourceCreatedBy")
  approvedResourceMetadata   resource_metadata[]             @relation("ResourceApprovedBy")
  userSecrets                user_secrets[]
}

model workflow_runs {
  id             String  @id @default(uuid())
  ran_by_user_id String
  status         String // "running" | "success" | "failed"
  started_at     BigInt
  completed_at   BigInt?
  args           String? // JSON string of input arguments passed to the workflow
  error_message  String?
  output         String? // Captured stdout/stderr from the workflow run
  workflow_slug  String
  session_id     String?
  message_id     String?
  user           users   @relation(fields: [ran_by_user_id], references: [id], onDelete: Cascade)

  @@index([started_at])
  @@index([session_id, message_id])
}

model workflow_aborted_sessions {
  session_id String @id
  created_at BigInt
}

model key_value {
  key   String @id
  value String
}

model user_secrets {
  id         String @id @default(uuid())
  user_id    String
  key        String
  value      String
  created_at BigInt
  updated_at BigInt
  user       users  @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, key])
  @@index([user_id])
}

model global_secrets {
  id                 String @id @default(uuid())
  key                String @unique
  value              String
  created_by_user_id String
  updated_by_user_id String
  created_at         BigInt
  updated_at         BigInt

  @@index([created_by_user_id])
  @@index([updated_by_user_id])
}

model chat_sessions {
  id                  String @id @default(uuid())
  user_id             String
  opencode_session_id String @unique
  title               String
  last_seen_assistant_message_id String?
  created_at          BigInt
  updated_at          BigInt
  trackedFiles        chat_session_tracked_files[]
  user                users                      @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model chat_session_tracked_files {
  id                  String        @id @default(uuid())
  chat_session_id     String
  relative_path       String
  existed_at_baseline Boolean
  content_kind        String // "text" | "binary" | "missing"
  text_content        String?
  binary_content      Bytes?
  size_bytes          Int?
  content_sha256      String?
  created_at          BigInt
  updated_at          BigInt
  session             chat_sessions @relation(fields: [chat_session_id], references: [id], onDelete: Cascade)

  @@unique([chat_session_id, relative_path])
  @@index([chat_session_id])
}

model tool_execution_permissions {
  id                  String  @id @default(uuid())
  opencode_session_id String
  message_id          String
  call_id             String
  status              String // "pending" | "approved" | "rejected"
  created_at          BigInt
  responded_at        BigInt?

  @@unique([opencode_session_id, message_id, call_id])
  @@index([opencode_session_id, status])
}

model resource_metadata {
  resource_kind       String
  resource_slug       String
  created_by_user_id  String?
  approved_by_user_id String?
  created_at          BigInt
  updated_at          BigInt
  approvedSnapshot    resource_approved_snapshots?
  createdByUser       users?                       @relation("ResourceCreatedBy", fields: [created_by_user_id], references: [id], onDelete: SetNull)
  approvedByUser      users?                       @relation("ResourceApprovedBy", fields: [approved_by_user_id], references: [id], onDelete: SetNull)

  @@id([resource_kind, resource_slug])
  @@index([resource_slug])
  @@index([created_by_user_id])
  @@index([approved_by_user_id])
}

model resource_permissions {
  resource_kind   String
  resource_slug   String
  permission_mode String // "restricted" | "everyone"
  created_at      BigInt
  updated_at      BigInt
  allowedUsers    resource_permission_users[]

  @@id([resource_kind, resource_slug])
  @@index([resource_slug])
}

model resource_permission_users {
  id            String               @id @default(uuid())
  resource_kind String
  resource_slug String
  user_id       String
  created_at    BigInt
  permission    resource_permissions @relation(fields: [resource_kind, resource_slug], references: [resource_kind, resource_slug], onDelete: Cascade)
  user          users                @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([resource_kind, resource_slug, user_id])
  @@index([resource_kind, resource_slug])
}

model resource_approved_snapshots {
  resource_kind String
  resource_slug String
  file_count    Int
  created_at    BigInt
  updated_at    BigInt
  resource      resource_metadata               @relation(fields: [resource_kind, resource_slug], references: [resource_kind, resource_slug], onDelete: Cascade)
  files         resource_approved_snapshot_files[]

  @@id([resource_kind, resource_slug])
  @@index([resource_slug])
}

model resource_approved_snapshot_files {
  id             String                      @id @default(uuid())
  resource_kind  String
  resource_slug  String
  relative_path  String
  content_kind   String // "text" | "binary"
  text_content   String?
  binary_content Bytes?
  size_bytes     Int
  content_sha256 String
  snapshot       resource_approved_snapshots @relation(fields: [resource_kind, resource_slug], references: [resource_kind, resource_slug], onDelete: Cascade)

  @@unique([resource_kind, resource_slug, relative_path])
  @@index([resource_kind, resource_slug])
}
