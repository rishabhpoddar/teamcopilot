generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model users {
  id                     String          @id @default(uuid())
  email                  String          @unique
  name                   String
  role                   String // "User" or "Engineer"
  created_at             BigInt
  password_hash          String
  reset_token            String?
  reset_token_expires_at BigInt?
  workflowRuns           workflow_runs[]
  chatSessions           chat_sessions[]
}

model workflow_runs {
  id             String  @id @default(uuid())
  ran_by_user_id String
  status         String // "running" | "success" | "failed"
  started_at     BigInt
  completed_at   BigInt?
  args           String? // JSON string of input arguments passed to the workflow
  error_message  String?
  output         String? // Captured stdout/stderr from the workflow run
  workflow_slug  String
  user           users   @relation(fields: [ran_by_user_id], references: [id], onDelete: Cascade)

  @@index([started_at])
}

model key_value {
  key   String @id
  value String
}

model chat_sessions {
  id                  String  @id @default(uuid())
  user_id             String
  opencode_session_id String  @unique
  title               String?
  created_at          BigInt
  updated_at          BigInt
  user                users   @relation(fields: [user_id], references: [id], onDelete: Cascade)
}
