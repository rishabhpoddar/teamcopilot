generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model users {
  id                         String                          @id @default(uuid())
  email                      String                          @unique
  name                       String
  role                       String // "User" or "Engineer"
  created_at                 BigInt
  password_hash              String
  must_change_password       Boolean                         @default(false)
  reset_token                String?
  reset_token_expires_at     BigInt?
  workflowRuns               workflow_runs[]
  chatSessions               chat_sessions[]
  workflowRunPermissionUsers workflow_run_permission_users[]
  createdWorkflowMetadata    workflow_metadata[]             @relation("WorkflowCreatedBy")
  approvedWorkflowMetadata   workflow_metadata[]             @relation("WorkflowApprovedBy")
}

model workflow_runs {
  id             String  @id @default(uuid())
  ran_by_user_id String
  status         String // "running" | "success" | "failed"
  started_at     BigInt
  completed_at   BigInt?
  args           String? // JSON string of input arguments passed to the workflow
  error_message  String?
  output         String? // Captured stdout/stderr from the workflow run
  workflow_slug  String
  user           users   @relation(fields: [ran_by_user_id], references: [id], onDelete: Cascade)
  log_ref        workflow_run_log_refs?

  @@index([started_at])
}

model workflow_run_log_refs {
  run_id     String        @id
  session_id String
  message_id String
  created_at BigInt
  run        workflow_runs @relation(fields: [run_id], references: [id], onDelete: Cascade)
}

model key_value {
  key   String @id
  value String
}

model chat_sessions {
  id                  String @id @default(uuid())
  user_id             String
  opencode_session_id String @unique
  title               String
  created_at          BigInt
  updated_at          BigInt
  user                users  @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model tool_execution_permissions {
  id                  String  @id @default(uuid())
  opencode_session_id String
  message_id          String
  call_id             String
  status              String // "pending" | "approved" | "rejected"
  created_at          BigInt
  responded_at        BigInt?

  @@unique([opencode_session_id, message_id, call_id])
  @@index([opencode_session_id, status])
}

model workflow_run_permission_users {
  id            String            @id @default(uuid())
  workflow_slug String
  user_id       String
  created_at    BigInt
  permission    workflow_metadata @relation(fields: [workflow_slug], references: [workflow_slug], onDelete: Cascade)
  user          users             @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([workflow_slug, user_id])
  @@index([workflow_slug])
}

model workflow_metadata {
  workflow_slug       String                          @id
  created_by_user_id  String?
  approved_by_user_id String?
  run_permission_mode String // "restricted" | "everyone"
  created_at          BigInt
  updated_at          BigInt
  allowedUsers        workflow_run_permission_users[]
  approvedSnapshot    workflow_approved_snapshots?
  createdByUser       users?                          @relation("WorkflowCreatedBy", fields: [created_by_user_id], references: [id], onDelete: SetNull)
  approvedByUser      users?                          @relation("WorkflowApprovedBy", fields: [approved_by_user_id], references: [id], onDelete: SetNull)

  @@index([created_by_user_id])
  @@index([approved_by_user_id])
}

model workflow_approved_snapshots {
  workflow_slug String                             @id
  file_count    Int
  created_at    BigInt
  updated_at    BigInt
  workflow      workflow_metadata                  @relation(fields: [workflow_slug], references: [workflow_slug], onDelete: Cascade)
  files         workflow_approved_snapshot_files[]
}

model workflow_approved_snapshot_files {
  id             String                      @id @default(uuid())
  workflow_slug  String
  relative_path  String
  content_kind   String // "text" | "binary"
  text_content   String?
  binary_content Bytes?
  size_bytes     Int
  content_sha256 String
  snapshot       workflow_approved_snapshots @relation(fields: [workflow_slug], references: [workflow_slug], onDelete: Cascade)

  @@unique([workflow_slug, relative_path])
  @@index([workflow_slug])
}
