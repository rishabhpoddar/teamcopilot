generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model users {
  id                     String  @id @default(uuid())
  email                  String  @unique
  name                   String
  role                   String  // "User" or "Engineer"
  created_at             BigInt
  password_hash          String
  reset_token            String?
  reset_token_expires_at BigInt?
}

model key_value {
  key   String @id
  value String
}
