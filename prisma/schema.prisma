generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model users {
  id             String @id @default(uuid())
  email          String @unique
  name           String
  created_at     BigInt
  google_user_id String @unique
}

model key_value {
  key   String @id
  value String
}
